{
  "name": "fint-admin-portal-frontend-v2",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve build/server/index.js",

    "typecheck": "react-router typegen && tsc",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",

    "cypress:open": "cypress open",
    "cypress:run": "cypress run",

    "cypress:open:cov": "CYPRESS_COVERAGE=true cypress open",
    "cypress:run:cov": "CYPRESS_COVERAGE=true cypress run",

    "coverage:text": "nyc report --reporter=text",
    "coverage:html": "nyc report --reporter=lcov",

    "coverage:clean": "rm -rf coverage .nyc_output"
  },

  "dependencies": {
    "@navikt/ds-css": "^7.25.1",
    "@navikt/ds-react": "^7.25.1",
    "@react-router/fs-routes": "7.8.2",
    "@react-router/node": "7.8.2",
    "@react-router/serve": "7.8.2",
    "isbot": "^5.1.17",
    "novari-frontend-components": "2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-json-pretty": "^2.2.0",
    "winston": "^3.17.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^3.14.6",
    "@react-router/dev": "7.8.2",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "autoprefixer": "^10.4.21",
    "cypress": "^15.2.0",
    "eslint": "^9.30.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-cypress": "^5.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.4.0",
    "istanbul-lib-coverage": "^3.2.2",
    "jasmine-core": "^5.10.0",
    "msw": "^2.10.2",
    "postcss": "^8.4.49",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "vite": "7.1.11",
    "vite-plugin-istanbul": "^7.2.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
